# Public site URL, used for SEO metadata, sitemap.xml, and robots.txt.
# Set to the real domain once it's connected (e.g. https://itsolutions.pk).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL of the corporate-portfolio-api backend (separate repo/deployment).
# The contact form POSTs to `${NEXT_PUBLIC_API_URL}/api/contact`.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Base URL of the corporate-portfolio-cms Strapi instance (separate repo/deployment).
STRAPI_URL=http://localhost:1337

# Read-only API token from Strapi admin (Settings > API Tokens > create a
# "read-only" token — Strapi read-only tokens cover every content type, so
# no per-type scoping is needed). This site fetches from all of: company-info,
# theme-setting, product-category, product, service, blog-post, testimonial,
# office, portfolio-category, project, stat, reason, client-logo — a token
# missing access to any one of these will break that section of the site
# (and, per app/error.tsx / lib/cms.ts's fallback logic, may fall back to
# placeholder content rather than a hard crash).
STRAPI_API_TOKEN=

# Public host that Strapi uploads (photos, videos) are served from. Strapi's
# default local-disk storage doesn't survive a redeploy on most container
# hosts (Railway included), so this project uses Cloudflare R2 instead — see
# corporate-portfolio-cms/config/plugins.ts. Set to R2's public dev URL (or
# a custom domain, if one is attached to the bucket later).
MEDIA_CDN_URL=
